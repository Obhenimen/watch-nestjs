# Copy this file to .env and fill in the values.
# .env is git-ignored — never commit real secrets.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./data/watchcue.sqlite

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must stay stable: login/sign and verify use this same value. If you change it,
# every existing token gets "invalid signature" until users log in again.
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Password Reset ────────────────────────────────────────────────────────────
RESET_TOKEN_TTL_MS=3600000
